# ── paths ────────────────────────────────────────────────────────────────────
KNOV_DATA_PATH=./data
KNOV_THEMES_PATH=./themes
KNOV_STORAGE_PATH=./storage
KNOV_LOGS_PATH=./logs

# ── server ───────────────────────────────────────────────────────────────────
KNOV_SERVER_PORT=1324

# ── logging ──────────────────────────────────────────────────────────────────
# stdout log level — options: debug, info, warning, error
KNOV_LOG_LEVEL=info

# file logging (writes to logs/app.log with rotation)
KNOV_LOG_FILE_ENABLED=true
# file log level — options: debug, info, warning, error (default: info)
KNOV_LOG_FILE_LEVEL=info
# max size in MB before rotating (default: 10)
KNOV_LOG_MAX_SIZE_MB=10
# number of rotated files to keep (default: 5)
KNOV_LOG_MAX_FILES=5

# ── git ──────────────────────────────────────────────────────────────────────
# remote sync (leave KNOV_GIT_REMOTE empty for local-only mode)
# if set and no local repo exists yet, knov will clone it on first start
KNOV_GIT_REMOTE=
KNOV_GIT_REMOTE_BRANCH=main
KNOV_GIT_AUTO_PUSH=true
KNOV_GIT_PUSH_TIMEOUT=10s

# HTTPS credentials (leave empty for SSH or local repo)
KNOV_GIT_USER=
KNOV_GIT_PASSWORD=
KNOV_GIT_TOKEN=

# SSH key path (leave empty to use ssh-agent or ~/.ssh/id_rsa, id_ed25519, id_ecdsa)
# set this if you use a non-default key file, e.g. ~/.ssh/id_rsa_privat
KNOV_GIT_SSH_KEY=

# ── storage providers ────────────────────────────────────────────────────────
# config storage: json
KNOV_CONFIG_STORAGE_PROVIDER=json

# metadata storage: json, yaml, sqlite
KNOV_METADATA_STORAGE_PROVIDER=json

# cache storage: json, sqlite
KNOV_CACHE_STORAGE_PROVIDER=sqlite

# search storage: sqlite
KNOV_SEARCH_STORAGE_PROVIDER=sqlite

# set to false to disable kanban event logging entirely
KNOV_KANBAN_EVENTS_ENABLED=true
# kanban events storage provider: sqlite
KNOV_KANBAN_EVENTS_STORAGE_PROVIDER=sqlite

# ── search ───────────────────────────────────────────────────────────────────
# options: repository, grep
KNOV_SEARCH_ENGINE=repository

# ── intervals ────────────────────────────────────────────────────────────────
KNOV_CRONJOB_INTERVAL=5m
KNOV_SEARCH_INDEX_INTERVAL=15m
KNOV_METADATA_REBUILD_INTERVAL=60m

# ── editor ───────────────────────────────────────────────────────────────────
# default editor for new and unassigned markdown files
# options: toastui-editor, codemirror-editor, textarea-editor (empty = use user setting)
KNOV_DEFAULT_EDITOR=

# ── notifications ────────────────────────────────────────────────────────────
# how long toast notifications stay visible, in milliseconds (default: 3500)
KNOV_NOTIFY_DURATION=3500

# ── kanban ───────────────────────────────────────────────────────────────────
# prefix used for kanban tags (e.g. "kb" → tag: kb-status-inbox)
KNOV_KANBAN_PREFIX=kb
# all possible kanban statuses (comma-separated, defines all valid tag values)
KNOV_KANBAN_STATUS=inbox,inprogress,blocked,archive
# visible columns on the board (subset of KNOV_KANBAN_STATUS)
KNOV_KANBAN_COLUMNS=inbox,inprogress,blocked
# tags automatically added to newly created files (comma-separated, empty = disabled).
# a bare tag (no ":") applies to every new file everywhere; a "folder/path:tag" entry only
# applies to files created under that folder (recursive - also covers subfolders)
# e.g. KNOV_AUTOCREATE_TAGS=starred, projects/work:kb-status-inbox, personal/todo:kb-status-inbox
KNOV_AUTOCREATE_TAGS=
# custom css colors for specific tags on the kanban board (tag:csscolor, comma-separated)
# e.g. KNOV_KANBAN_TAG_COLORS=username:green,urgent:red,blocked:orange
KNOV_KANBAN_TAG_COLORS=
# card style per kanban status (status:style, comma-separated); styles: normal, italic, highlighted, deleted
# e.g. KNOV_KANBAN_CARD_STYLES=blocked:italic,waiting:italic,urgent:highlighted,done:deleted,archive:deleted
KNOV_KANBAN_CARD_STYLES=
# status used for the archive drop zone shown while dragging (empty = disable the archive zone)
KNOV_KANBAN_ARCHIVE_STATUS=archive
# kanban boards (folder/path:Display Name, comma-separated); each board covers that folder and
# its subfolders. The URL slug is derived from the folder path automatically.
# e.g. KNOV_KANBAN_BOARDS=projects/work:Work Board,personal/todo:Personal Todo
KNOV_KANBAN_BOARDS=

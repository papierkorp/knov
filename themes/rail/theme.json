{
  "name": "Rail",
  "version": "2.0.0",
  "author": "System",
  "description": "icon rail with slide-out flyout panels",
  "themeSettings": {
    "darkMode": {
      "type": "boolean",
      "default": true,
      "label": "Dark Mode",
      "description": "enable dark theme appearance"
    },
    "colorScheme": {
      "type": "select",
      "options": ["blue", "green", "red", "purple"],
      "default": "green",
      "label": "Color Scheme",
      "description": "choose the color theme"
    },
    "fontFamily": {
      "type": "select",
      "options": ["system", "serif", "mono"],
      "default": "system",
      "label": "Font Family",
      "description": "select the font style"
    },
    "customCSS": {
      "type": "textarea",
      "default": "",
      "label": "Custom CSS",
      "description": "add your own css styles"
    }
  }
}

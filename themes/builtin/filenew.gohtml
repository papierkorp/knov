{{/* theme: builtin */}}
{{ define "content" }}
<div id="page-filenew">
    <h1>{{ T "Create New File" }}</h1>
	<div class="file-create-form">
		<div
			hx-get="/api/editor?editor={{ .Editor }}"
			hx-trigger="load"
			hx-target="this"
			hx-swap="outerHTML"
		>
			loading editor...
		</div>
	</div>
</div>
{{ end }}
